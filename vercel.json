{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/animation", "dest": "/animation.html" },
    { "src": "/blog", "dest": "/blog/index.html" },
    { "src": "/blog/(.*)", "dest": "/blog/$1/index.html" },
    { "src": "/app", "dest": "/app/index.html" },
    { "src": "/privacy", "dest": "/app/index.html" },
    { "src": "/terms", "dest": "/app/index.html" },
    { "src": "/about", "dest": "/app/index.html" },
    { "src": "/contact", "dest": "/app/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
